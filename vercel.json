{
  "version": 2,
  "framework": null,
  "installCommand": "git clone https://github.com/flutter/flutter.git --depth 1 -b 3.41.9 _flutter && _flutter/bin/flutter --version",
  "buildCommand": "_flutter/bin/flutter build web --release --no-tree-shake-icons",
  "outputDirectory": "build/web",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
